{
    "name": "componenta/http-body-parsing-middleware",
    "description": "PSR-15 request body parsing middleware for Componenta",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/config": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Http\\Middleware\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Http\\Middleware\\BodyParsingConfigProvider"
            ]
        }
    }
}
